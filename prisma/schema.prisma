generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@index([userId])
  @@index([expires])
}

model User {
  id                 String         @id @default(cuid())
  name               String?
  email              String?        @unique
  emailVerified      DateTime?      @map("email_verified")
  image              String?
  accounts           Account[]
  sessions           Session[]
  ownedOrganizations Organization[] @relation("OrganizationOwner")
  ownedTeams         Team[]         @relation("TeamOwner")
  memberships        TeamMember[]
  organizationInvitations OrganizationInvitation[]
  worklogs           Worklog[]
  ratings            Rating[]
  idempotencyKeys    IdempotencyKey[]

  @@map("users")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  description String?
  credits     Int      @default(0)  // Credits system for organization
  ownerId     String   @map("owner_id")
  owner       User     @relation("OrganizationOwner", fields: [ownerId], references: [id])
  teams       Team[]
  invitations OrganizationInvitation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("organizations")
  @@index([ownerId])
}

model Team {
  id                     String        @id @default(cuid())
  name                   String
  description            String?
  project                String?
  credits                Int           @default(0)  // Credits system for team
  organizationId         String?       @map("organization_id")
  organization           Organization? @relation(fields: [organizationId], references: [id])
  organizationWasDeleted Boolean       @default(false) @map("organization_was_deleted")
  ownerId                String        @map("owner_id")
  owner                  User          @relation("TeamOwner", fields: [ownerId], references: [id])
  members                TeamMember[]
  worklogs               Worklog[]
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@map("teams")
  @@index([organizationId])
  @@index([ownerId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id")
  userId    String?  @map("user_id")
  email     String
  token     String?  @unique // Invitation token
  status    MemberStatus @default(PENDING)
  invitedAt DateTime @default(now())
  joinedAt  DateTime?
  expiresAt DateTime? @map("expires_at") // Invitation expiration (null = no expiry)

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@unique([teamId, email])
  @@index([userId])
  @@index([status])
  @@index([expiresAt]) // For efficient cleanup queries
  @@index([userId, status]) // Composite index for efficient filtering by both userId and status
  @@index([teamId, status]) // Optimize fetching team members by status
  @@map("team_members")
}

model OrganizationInvitation {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String?  @map("user_id")
  email          String
  token          String?  @unique // Invitation token
  status         MemberStatus @default(PENDING)
  invitedAt      DateTime @default(now())
  joinedAt       DateTime?
  expiresAt      DateTime? @map("expires_at") // Invitation expiration (null = no expiry)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@unique([organizationId, email])
  @@index([userId])
  @@index([status])
  @@index([expiresAt]) // For efficient cleanup queries
  @@index([userId, status])
  @@index([organizationId, status])
  @@map("organization_invitations")
}

enum MemberStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ProgressStatus {
  STARTED
  HALF_DONE
  COMPLETED
  REVIEWED
  GRADED
}

model Worklog {
  id             String         @id @default(cuid())
  title          String
  description    String         @db.Text
  githubLink     String?
  progressStatus ProgressStatus @default(STARTED)
  deadline       DateTime?
  userId         String         @map("user_id")
  teamId         String         @map("team_id")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  team        Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  ratings     Rating[]
  attachments WorklogAttachment[]

  @@map("worklogs")
  @@index([userId])
  @@index([teamId])
  @@index([userId, progressStatus])
  @@index([teamId, progressStatus]) // Optimize pending review count queries (WHERE teamId=X AND progressStatus='COMPLETED')
  @@index([userId, createdAt]) // Composite index for efficient user worklog queries with ordering
  @@index([teamId, createdAt]) // Optimize team worklogs fetching
  @@index([createdAt])
  @@index([deadline])
}

model WorklogAttachment {
  id        String   @id @default(cuid())
  worklogId String   @map("worklog_id")
  url       String
  fileName  String
  mimeType  String
  size      Int
  kind      String
  createdAt DateTime @default(now())

  worklog Worklog @relation(fields: [worklogId], references: [id], onDelete: Cascade)

  @@map("worklog_attachments")
}

model Rating {
  id        String   @id @default(cuid())
  value     Int      // 1-10 scale
  comment   String?  @db.Text
  worklogId String   @map("worklog_id")
  raterId   String   @map("rater_id")  // Organization owner who rated
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worklog Worklog @relation(fields: [worklogId], references: [id], onDelete: Cascade)
  rater   User    @relation(fields: [raterId], references: [id], onDelete: Cascade)

  @@unique([worklogId, raterId])  // One rating per worklog per rater
  @@map("ratings")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Email Infrastructure ───────────────────────────────────────────────────

model EmailLog {
  id              String    @id @default(cuid())
  recipientEmail  String    @map("recipient_email")
  subject         String
  emailType       String    @map("email_type") // TEAM_INVITE, ORG_INVITE, WORKLOG_REVIEW, DEADLINE_REMINDER
  templateName    String    @map("template_name") // TeamInvitation, OrganizationInvitation, etc.
  resendMessageId String?   @unique @map("resend_message_id")
  idempotencyKey  String?   @map("idempotency_key")
  status          String    @default("QUEUED") // QUEUED, SENT, DELIVERED, BOUNCED, COMPLAINED, FAILED
  requestId       String    @unique @map("request_id")
  sentAt          DateTime? @map("sent_at")
  deliveredAt     DateTime? @map("delivered_at")
  failureReason   String?   @map("failure_reason")
  retryCount      Int       @default(0) @map("retry_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("email_logs")
  @@index([recipientEmail])
  @@index([status])
  @@index([emailType])
  @@index([createdAt])
  @@index([resendMessageId])
}

model EmailSuppression {
  id           String   @id @default(cuid())
  email        String   @unique
  reason       String   // HARD_BOUNCE, SOFT_BOUNCE, COMPLAINED, UNSUBSCRIBED
  bounceType   String?  @map("bounce_type") // permanent, transient, undetermined
  suppressedAt DateTime @default(now()) @map("suppressed_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("email_suppressions")
  @@index([email])
  @@index([reason])
}

/// Server-side request deduplication.
/// Every state-mutating HTTP request (POST/PATCH/DELETE) receives a unique
/// Idempotency-Key header from the client.  On first receipt the key is stored
/// here together with the response status + body.  Subsequent requests with
/// the same key (same user + token) return the cached response immediately,
/// preventing duplicates from rapid clicks or network retries.
/// Cleanup: keys older than 24 h are removed by the daily cron job.
model IdempotencyKey {
  id            String   @id @default(cuid())
  token         String   @unique
  userId        String   @map("user_id")
  operationType String   @map("operation_type") // e.g. "CREATE_TEAM", "CREATE_WORKLOG"
  operationId   String?  @map("operation_id")  // ID of the created/affected resource (nullable)
  responseStatus Int     @map("response_status") // HTTP status stored for replay
  responseBody  String   @map("response_body") @db.Text // Serialised JSON response for replay
  createdAt     DateTime @default(now()) @map("created_at")
  expiresAt     DateTime @map("expires_at")   // createdAt + 24 h

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt]) // For efficient cleanup/expiry queries
  @@map("idempotency_keys")
}
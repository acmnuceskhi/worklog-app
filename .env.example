# Worklog App - Environment Variables
# Copy this file to .env and fill in your actual credentials for development.
# For production, use Vercel dashboard, GitHub secrets, or your deployment platform's env var management.

# ─────────────────────────────────────────────────────────────────────────────
# NODE ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string. Format: postgresql://username:password@host:port/dbname
# For local development: postgresql://postgres:password@localhost:5432/worklog_app
# For Prisma Cloud: provided in your project settings
DATABASE_URL="postgresql://postgres:password@localhost:5432/worklog_app"

# Prisma ORM optimization. Get your API key from https://www.prisma.io/docs/platforms/proxy
# Optional in development, required for production performance monitoring
OPTIMIZE_API_KEY="your-prisma-optimize-api-key"

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION (Auth.js + OAuth)
# ─────────────────────────────────────────────────────────────────────────────

# Random 32+ byte string used to encrypt Auth.js session tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="your-random-32-byte-hex-string-here"

# NextAuth redirect URL. Must match your app's base URL
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth Credentials
# Create app at: https://github.com/settings/developers (Settings > Developer settings > OAuth Apps)
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"

# Google OAuth Credentials
# Create app at: https://console.cloud.google.com (APIs & Services > Credentials)
# Configure OAuth consent screen with your domain first
AUTH_GOOGLE_ID="your-google-oauth-app-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-oauth-app-secret"

# Trust host for local production testing (npm run start).
# Required to prevent UntrustedHost redirect loops in production mode locally.
# On Vercel, Auth.js auto-detects the host via the VERCEL env var — do NOT add this to Vercel.
AUTH_TRUST_HOST=true

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (Resend)
# ─────────────────────────────────────────────────────────────────────────────

# Resend API Key for sending transactional emails (invitations, notifications)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# Webhook secret for Resend events (bounces, complaints, delivery)
# Configure in Resend dashboard at: https://resend.com/webhooks
# After creating webhook endpoint pointing to /api/webhooks/resend
RESEND_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# From address for all transactional emails
# Must be a verified domain in Resend. Defaults to hello@worklog-app.com if unset.
# Example: "Worklog App <noreply@mail.worklog-app.com>" (when using custom domain)
# Best practice: Use a monitored inbox (not noreply@)
EMAIL_FROM="Worklog App <hello@worklog-app.com>"

# ─────────────────────────────────────────────────────────────────────────────
# CRON JOBS (Vercel Cron)
# ─────────────────────────────────────────────────────────────────────────────

# Secret for protecting cron endpoints (cleanup-expired-invitations)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="your-random-32-byte-hex-string-for-cron"

# ─────────────────────────────────────────────────────────────────────────────
# MONITORING & OBSERVABILITY (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Sentry error tracking DSN (optional)
# Get at: https://sentry.io/organizations/your-org/projects/
# Leave blank to disable error reporting
SENTRY_DSN=""

# ─────────────────────────────────────────────────────────────────────────────
# PAGINATION & LIMITS (Optional - Advanced)
# ─────────────────────────────────────────────────────────────────────────────

# Max worklogs to fetch in list endpoint (API route filter)
# Default: 100 | Increase for larger datasets
WORKLOG_LIST_LIMIT="100"

# Max worklogs to fetch for team members (API route filter)
# Default: 100 | Increase for larger teams
WORKLOG_FETCH_LIMIT="100"

# Default items per page in pagination
# Default: 25
PAGINATION_DEFAULT_LIMIT="25"

# Maximum items per page allowed (prevents abuse)
# Default: 100
PAGINATION_MAX_LIMIT="100"

# ─────────────────────────────────────────────────────────────────────────────
# BUNDLE ANALYSIS (Optional - Development Only)
# ─────────────────────────────────────────────────────────────────────────────

# Enable Next.js bundle analysis on build
# Set to "true" to generate bundle analysis report at .next/analyze
ANALYZE="false"